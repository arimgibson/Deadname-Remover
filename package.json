{
  "name": "Deadname Remover",
  "version": "2.2.0",
  "description": "An easy to use browser plugin to automatically remove and replace deadnames",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arimgibson/Deadname-Remover.git"
  },
  "keywords": [
    "trans",
    "transgender",
    "dead",
    "name",
    "deadname",
    "lgbtq",
    "lgbtq+",
    "queer",
    "non-binary",
    "gender"
  ],
  "author": "Ari Gibson",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/arimgibson/Deadname-Remover/issues"
  },
  "homepage": "https://github.com/arimgibson/Deadname-Remover#readme",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "lint": "eslint .",
    "check": "svelte-check --tsconfig ./tsconfig.json && tsc --noEmit",
    "test": "vitest",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@iconify-json/material-symbols": "^1.2.48",
    "@iconify-json/twemoji": "^1.2.4",
    "@onu-ui/preset": "^1.1.5",
    "@stylistic/eslint-plugin": "^5.6.1",
    "@types/chrome": "^0.1.31",
    "@typescript-eslint/parser": "^8.48.0",
    "@wxt-dev/module-svelte": "^2.0.4",
    "@wxt-dev/unocss": "^1.0.1",
    "eslint": "^9.39.1",
    "eslint-plugin-svelte": "^3.13.0",
    "globals": "^16.5.0",
    "svelte": "^5.45.2",
    "svelte-check": "^4.3.4",
    "svelte-eslint-parser": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "unocss": "^66.5.9",
    "vitest": "^4.0.14",
    "wxt": "^0.20.11"
  },
  "dependencies": {
    "browser-extension-url-match": "^1.2.0",
    "compare-versions": "^6.1.1",
    "microdiff": "^1.5.0",
    "svelte-french-toast": "^1.2.0",
    "text-security": "^3.2.1",
    "valibot": "^1.2.0"
  }
}
