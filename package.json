{
  "name": "Deadname Remover",
  "version": "2.2.2",
  "description": "An easy to use browser plugin to automatically remove and replace deadnames",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arimgibson/Deadname-Remover.git"
  },
  "keywords": [
    "trans",
    "transgender",
    "dead",
    "name",
    "deadname",
    "lgbtq",
    "lgbtq+",
    "queer",
    "non-binary",
    "gender"
  ],
  "author": "Ari Gibson",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/arimgibson/Deadname-Remover/issues"
  },
  "homepage": "https://github.com/arimgibson/Deadname-Remover#readme",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "lint": "eslint .",
    "check": "svelte-check --tsconfig ./tsconfig.json && tsc --noEmit",
    "test": "vitest",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@iconify-json/material-symbols": "^1.2.53",
    "@iconify-json/twemoji": "^1.2.5",
    "@onu-ui/preset": "^1.1.5",
    "@stylistic/eslint-plugin": "^5.7.1",
    "@types/chrome": "^0.1.36",
    "@typescript-eslint/parser": "^8.54.0",
    "@wxt-dev/module-svelte": "^2.0.4",
    "@wxt-dev/unocss": "^1.0.1",
    "eslint": "^9.39.2",
    "eslint-plugin-svelte": "^3.14.0",
    "globals": "^17.2.0",
    "svelte": "^5.49.0",
    "svelte-check": "^4.3.5",
    "svelte-eslint-parser": "^1.4.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.54.0",
    "unocss": "^66.6.0",
    "vitest": "^4.0.18",
    "wxt": "^0.20.13"
  },
  "dependencies": {
    "compare-versions": "^6.1.1",
    "microdiff": "^1.5.0",
    "svelte-french-toast": "^1.2.0",
    "text-security": "^3.2.1",
    "valibot": "^1.2.0"
  }
}
